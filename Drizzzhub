local function createPage()
    local scroll = Instance.new("ScrollingFrame", contentArea)
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.ScrollBarThickness = 3
    scroll.BackgroundTransparency = 1
    scroll.Visible = false
    scroll.ScrollBarImageColor3 = Color3.fromRGB(0, 150, 255)
    local layout = Instance.new("UIListLayout", scroll)
    layout.Padding = UDim.new(0, 5)
    local pad = Instance.new("UIPadding", scroll)
    pad.PaddingTop = UDim.new(0, 5)
    pad.PaddingRight = UDim.new(0, 5)
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 15)
    end)
    return scroll
end

local function createTab(icon_text, label)
    local tabBtn = Instance.new("TextButton", sidebar)
    tabBtn.Size = UDim2.new(1, 0, 0, 38)
    tabBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 40)
    tabBtn.TextColor3 = Color3.fromRGB(160, 160, 180)
    tabBtn.TextScaled = true
    tabBtn.Font = Enum.Font.GothamBold
    tabBtn.Text = icon_text .. "\n" .. label
    tabBtn.BackgroundTransparency = 0.3
    Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, 8)

    local indicator = Instance.new("Frame", tabBtn)
    indicator.Size = UDim2.new(0, 3, 0.7, 0)
    indicator.Position = UDim2.new(0, 0, 0.15, 0)
    indicator.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    indicator.Visible = false
    Instance.new("UICorner", indicator).CornerRadius = UDim.new(1, 0)

    local page = createPage()

    tabBtn.MouseButton1Click:Connect(function()
        for _, t in pairs(tabButtons) do
            TweenService:Create(t.btn, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(25, 25, 40),
                TextColor3 = Color3.fromRGB(160, 160, 180)
            }):Play()
            t.indicator.Visible = false
            t.page.Visible = false
        end
        TweenService:Create(tabBtn, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(0, 80, 160),
            TextColor3 = Color3.fromRGB(255, 255, 255)
        }):Play()
        indicator.Visible = true
        page.Visible = true
        activeTab = tabBtn
    end)

    table.insert(tabButtons, {btn = tabBtn, indicator = indicator, page = page})
    return page
end

local function createButton(parent, name, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -8, 0, 32)
    btn.Text = "  " .. name
    btn.BackgroundColor3 = Color3.fromRGB(25, 25, 45)
    btn.TextColor3 = Color3.fromRGB(200, 200, 220)
    btn.TextScaled = true
    btn.Font = Enum.Font.Gotham
    btn.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local s = Instance.new("UIStroke", btn)
    s.Thickness = 1
    s.Color = Color3.fromRGB(40, 40, 70)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(0, 80, 160)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(25, 25, 45)}):Play()
    end)
    btn.MouseButton1Click:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.08), {BackgroundColor3 = Color3.fromRGB(0, 120, 255)}):Play()
        task.wait(0.08)
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(0, 80, 160)}):Play()
        callback()
    end)
end

