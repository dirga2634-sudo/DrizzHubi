    Instance.new("UICorner", box).CornerRadius = UDim.new(0,6)
    Instance.new("UIStroke", box).Color = Color3.fromRGB(0,100,200)

    local setBtn = Instance.new("TextButton", inputRow)
    setBtn.Size = UDim2.new(0.22,0,1,0)
    setBtn.Text = currentLang.set_btn
    setBtn.BackgroundColor3 = Color3.fromRGB(0,150,255)
    setBtn.TextColor3 = Color3.new(1,1,1)
    setBtn.TextScaled = true
    setBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", setBtn).CornerRadius = UDim.new(0,6)

    local resetBtn = Instance.new("TextButton", inputRow)
    resetBtn.Size = UDim2.new(0.2,0,1,0)
    resetBtn.Text = "↺"
    resetBtn.BackgroundColor3 = Color3.fromRGB(60,60,100)
    resetBtn.TextColor3 = Color3.new(1,1,1)
    resetBtn.TextScaled = true
    Instance.new("UICorner", resetBtn).CornerRadius = UDim.new(0,6)

    setBtn.MouseButton1Click:Connect(function()
        local val = tonumber(box.Text)
        if val and val >= 1 and val <= maxVal then
            callback(val, false)
            setBtn.Text = "✓"
            setBtn.BackgroundColor3 = Color3.fromRGB(0,180,80)
            task.wait(1.5)
            setBtn.Text = currentLang.set_btn
            setBtn.BackgroundColor3 = Color3.fromRGB(0,150,255)
        else
            setBtn.Text = "!"
            setBtn.BackgroundColor3 = Color3.fromRGB(200,50,50)
            task.wait(1.5)
            setBtn.Text = currentLang.set_btn
            setBtn.BackgroundColor3 = Color3.fromRGB(0,150,255)
        end
    end)
    resetBtn.MouseButton1Click:Connect(function()
        box.Text = ""
        callback(nil, true)
    end)

    table.insert(allTexts, {obj=lbl, key=labelKey, type="text"})
    table.insert(allTexts, {obj=box, key=phKey, type="ph"})
    table.insert(allTexts, {obj=setBtn, key="set_btn", type="text"})
end

