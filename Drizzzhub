local function createToggle(parent, name, callback)
    local toggleOn = false
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1, -8, 0, 32)
    row.BackgroundColor3 = Color3.fromRGB(25, 25, 45)
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", row).Color = Color3.fromRGB(40, 40, 70)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, -50, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.Text = name
    lbl.TextColor3 = Color3.fromRGB(200, 200, 220)
    lbl.BackgroundTransparency = 1
    lbl.TextScaled = true
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local toggleBg = Instance.new("Frame", row)
    toggleBg.Size = UDim2.new(0, 36, 0, 20)
    toggleBg.Position = UDim2.new(1, -42, 0.5, -10)
    toggleBg.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    Instance.new("UICorner", toggleBg).CornerRadius = UDim.new(1, 0)

    local toggleDot = Instance.new("Frame", toggleBg)
    toggleDot.Size = UDim2.new(0, 16, 0, 16)
    toggleDot.Position = UDim2.new(0, 2, 0.5, -8)
    toggleDot.BackgroundColor3 = Color3.fromRGB(180, 180, 200)
    Instance.new("UICorner", toggleDot).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton", row)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""

    btn.MouseButton1Click:Connect(function()
        toggleOn = not toggleOn
        if toggleOn then
            TweenService:Create(toggleBg, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 150, 255)}):Play()
            TweenService:Create(toggleDot, TweenInfo.new(0.2), {Position = UDim2.new(0, 18, 0.5, -8), BackgroundColor3 = Color3.fromRGB(255,255,255)}):Play()
        else
            TweenService:Create(toggleBg, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(60, 60, 80)}):Play()
            TweenService:Create(toggleDot, TweenInfo.new(0.2), {Position = UDim2.new(0, 2, 0.5, -8), BackgroundColor3 = Color3.fromRGB(180,180,200)}):Play()
        end
        callback(toggleOn)
    end)
end

local function createInput(parent, labelText, placeholder, maxVal, callback)
    local lbl = Instance.new("TextLabel", parent)
    lbl.Size = UDim2.new(1, -8, 0, 18)
    lbl.Text = labelText
    lbl.TextColor3 = Color3.fromRGB(0, 200, 255)
    lbl.BackgroundTransparency = 1
    lbl.TextScaled = true
    lbl.Font = Enum.Font.GothamBold
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local inputRow = Instance.new("Frame", parent)
    inputRow.Size = UDim2.new(1, -8, 0, 32)
    inputRow.BackgroundTransparency = 1

    local inputLayout = Instance.new("UIListLayout", inputRow)
    inputLayout.FillDirection = Enum.FillDirection.Horizontal
    inputLayout.Padding = UDim.new(0, 4)

    local box = Instance.new("TextBox", inputRow)
    box.Size = UDim2.new(0.55, 0, 1, 0)
    box.PlaceholderText = placeholder
    box.BackgroundColor3 = Color3.fromRGB(20, 20, 38)
    box.TextColor3 = Color3.new(1, 1, 1)
    box.TextScaled = true
    box.Font = Enum.Font.Gotham
    box.ClearTextOnFocus = false
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", box).Color = Color3.fromRGB(0, 100, 200)

    local setBtn = Instance.new("TextButton", inputRow)
    setBtn.Size = UDim2.new(0.22, 0, 1, 0)
    setBtn.Text = "Set"
    setBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    setBtn.TextColor3 = Color3.new(1, 1, 1)
    setBtn.TextScaled = true
    setBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", setBtn).CornerRadius = UDim.new(0, 6)

    local resetBtn = Instance.new("TextButton", inputRow)
    resetBtn.Size = UDim2.new(0.2, 0, 1, 0)
    resetBtn.Text = "↺"
    resetBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 100)
    resetBtn.TextColor3 = Color3.new(1, 1, 1)
    resetBtn.TextScaled = true
    Instance.new("UICorner", resetBtn).CornerRadius = UDim.new(0, 6)

    setBtn.MouseButton1Click:Connect(function()
        local val = tonumber(box.Text)
        if val and val >= 1 and val <= maxVal then
            callback(val, false)
            setBtn.Text = "✓"
            setBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 80)
            task.wait(1.5)
            setBtn.Text = "Set"
            setBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
        else
            setBtn.Text = "!"
            setBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            task.wait(1.5)
            setBtn.Text = "Set"
            setBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
        end
    end)

    resetBtn.MouseButton1Click:Connect(function()
        box.Text = ""
        callback(nil, true)
    end)
end

