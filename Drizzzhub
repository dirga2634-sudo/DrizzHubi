local function applyLanguage(lang)
    currentLang = lang
    topTitle.Text = lang.hub_title
    watermark.Text = lang.watermark
    for _, t in pairs(tabButtons) do
        t.btn.Text = lang[t.key]
    end
    for _, item in pairs(allTexts) do
        if lang[item.key] then
            if item.type == "ph" then
                item.obj.PlaceholderText = lang[item.key]
            elseif item.type == "btn" then
                item.obj.Text = "  "..lang[item.key]
            else
                item.obj.Text = lang[item.key]
            end
        end
    end
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "🌍 Language",
            Text = lang.flag.." Changed to "..lang.name,
            Duration = 3
        })
    end)
end

