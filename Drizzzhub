createLabel(langPage, "lang_title", Color3.fromRGB(0,200,255))
createLabel(langPage, "lang_desc", Color3.fromRGB(180,180,200))

local langList = {
    {code="EN", color=Color3.fromRGB(0,80,200)},
    {code="ID", color=Color3.fromRGB(220,50,50)},
    {code="JP", color=Color3.fromRGB(200,50,80)},
    {code="AR", color=Color3.fromRGB(0,150,50)},
    {code="MY", color=Color3.fromRGB(0,80,160)},
    {code="CN", color=Color3.fromRGB(200,30,30)},
    {code="JV", color=Color3.fromRGB(120,80,30)},
    {code="DK", color=Color3.fromRGB(30,130,60)},
}

for _, l in ipairs(langList) do
    local lang = languages[l.code]
    local langBtn = Instance.new("TextButton", langPage)
    langBtn.Size = UDim2.new(1,-8,0,36)
    langBtn.Text = lang.flag.."  "..lang.name
    langBtn.BackgroundColor3 = l.color
    langBtn.TextColor3 = Color3.new(1,1,1)
    langBtn.TextScaled = true
    langBtn.Font = Enum.Font.GothamBold
    langBtn.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", langBtn).CornerRadius = UDim.new(0,6)
    local lp = Instance.new("UIPadding", langBtn)
    lp.PaddingLeft = UDim.new(0,12)

    langBtn.MouseButton1Click:Connect(function()
        TweenService:Create(langBtn, TweenInfo.new(0.1), {Size=UDim2.new(1,-8,0,26)}):Play()
        task.wait(0.1)
        TweenService:Create(langBtn, TweenInfo.new(0.2, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {Size=UDim2.new(1,-8,0,36)}):Play()
        applyLanguage(lang)
    end)
end
